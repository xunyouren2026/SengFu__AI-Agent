# =============================================================================
# AGI Unified Framework - Environment Configuration Template
# =============================================================================
# 复制此文件为 .env 并根据需要修改配置值
# cp .env.example .env
# =============================================================================

# =============================================================================
# 应用基础配置
# =============================================================================
APP_NAME=AGI Unified Framework
APP_ENV=production
APP_DEBUG=false
APP_VERSION=1.0.0

# 应用密钥（用于会话加密等，请使用强随机字符串）
APP_SECRET_KEY=your-32-character-secret-key-here

# =============================================================================
# 服务器配置
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=4
TIMEOUT=120
GRACEFUL_TIMEOUT=30
KEEP_ALIVE=5

# =============================================================================
# 数据库配置 (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=agi_user
DB_PASSWORD=your-secure-db-password
DB_NAME=agi_framework

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 完整数据库URL（可选，如果不设置则使用上述配置自动构建）
# DATABASE_URL=postgresql://agi_user:password@localhost:5432/agi_framework

# =============================================================================
# Redis配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_SSL=false

# Redis集群配置（如果使用集群）
# REDIS_CLUSTER_NODES=node1:6379,node2:6379,node3:6379

# =============================================================================
# 消息队列配置 (Celery)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# =============================================================================
# JWT认证配置
# =============================================================================
JWT_SECRET_KEY=your-jwt-secret-key-min-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# 外部AI API配置
# =============================================================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# Azure OpenAI
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_VERSION=2024-02-01

# =============================================================================
# 对象存储配置 (S3/MinIO)
# =============================================================================
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=agi-assets
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PATH_STYLE=true

# =============================================================================
# 向量数据库配置 (Milvus/Qdrant)
# =============================================================================
VECTOR_DB_TYPE=milvus
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=19530
VECTOR_DB_COLLECTION=agi_documents

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE=/var/log/agi-framework/app.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# =============================================================================
# 监控配置
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_PATH=/health

# Jaeger链路追踪
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1

# =============================================================================
# 安全配置
# =============================================================================
# CORS配置
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_CREDENTIALS=true

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/3

# =============================================================================
# 文件上传配置
# =============================================================================
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=txt,md,pdf,doc,docx,png,jpg,jpeg,gif,mp3,mp4,wav
UPLOAD_CHUNK_SIZE=1048576

# =============================================================================
# 邮件服务配置
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_TLS=true

# =============================================================================
# OAuth配置
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# 模型服务配置
# =============================================================================
MODEL_SERVICE_URL=http://localhost:8080
EMBEDDING_SERVICE_URL=http://localhost:8081
MODEL_TIMEOUT=60
MODEL_MAX_RETRIES=3
MODEL_RETRY_DELAY=1

# =============================================================================
# 缓存配置
# =============================================================================
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=agi:

# =============================================================================
# 部署配置
# =============================================================================
DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443
API_PORT=8000

# 数据目录
DATA_DIR=./data

# Docker镜像配置
DOCKER_REGISTRY=registry.company.com
DOCKER_IMAGE=agi-framework
DOCKER_TAG=1.0.0

# Kubernetes配置
K8S_NAMESPACE=agi-framework-prod
K8S_CONTEXT=production

# =============================================================================
# 开发配置（仅在开发环境使用）
# =============================================================================
# DEBUG_TOOLBAR=true
# SQL_ECHO=true
# RELOAD_ON_CHANGE=true
