  "AGI Training Loop": {
    "prefix": "agi-train",
    "body": [
      "from agi_framework.training import Trainer",
      "from agi_framework.data import DataLoader",
      "",
      "def train_model(model, train_data, val_data, config):",
      "    \"\"\"Train a model with AGI Framework\"\"\"",
      "    ",
      "    # Initialize trainer",
      "    trainer = Trainer(",
      "        model=model,",
      "        config=config,",
      "        optimizer='adam',",
      "        learning_rate=${1:0.001}",
      "    )",
      "    ",
      "    # Create data loaders",
      "    train_loader = DataLoader(train_data, batch_size=${2:32})",
      "    val_loader = DataLoader(val_data, batch_size=${2:32})",
      "    ",
      "    # Training loop",
      "    for epoch in range(${3:10}):",
      "        # Train",
      "        train_loss = trainer.train_epoch(train_loader)",
      "        ",
      "        # Validate",
      "        val_loss, val_metrics = trainer.validate(val_loader)",
      "        ",
      "        # Log metrics",
      "        trainer.log_metrics({",
      "            'epoch': epoch,",
      "            'train_loss': train_loss,",
      "            'val_loss': val_loss,",
      "            **val_metrics",
      "        })",
      "        ",
      "        # Save checkpoint",
      "        if epoch % ${4:5} == 0:",
      "            trainer.save_checkpoint(f'checkpoint_epoch_{epoch}.pt')",
      "    ",
      "    return trainer"
    ],
    "description": "Create a standard AGI Framework training loop"
  },
