{
  "AGI Model Config": {
    "prefix": "agi-model-config",
    "body": [
      "{",
      "  \"model\": {",
      "    \"name\": \"${1:my-model}\",",
      "    \"version\": \"${2:1.0.0}\",",
      "    \"type\": \"${3|transformer,cnn,rnn,llm|}\",",
      "    \"architecture\": {",
      "      \"hidden_size\": ${4:768},",
      "      \"num_layers\": ${5:12},",
      "      \"num_heads\": ${6:12},",
      "      \"dropout\": ${7:0.1}",
      "    }",
      "  },",
      "  \"training\": {",
      "    \"batch_size\": ${8:32},",
